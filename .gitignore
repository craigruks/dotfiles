# System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# Ignore gitignore files in subdirectories, but DO track the root one so the
# ignore + secret-protection rules below ship with the repo to every clone.
**/.gitignore
!/.gitignore

# Neovim (LazyVim). Runtime junk (data/, *.log) is ignored by .config/nvim/.gitignore.
# lazy-lock.json IS tracked on purpose - it pins exact plugin commits for reproducibility.

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Rust
/target/
**/*.rs.bk
Cargo.lock

# Java
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env files - may hold real secrets (the incremental "gitignored .env" approach).
# Examples/schemas stay committable for the eventual varlock + 1Password setup.
.env
.env.*
*.env
!.env.example
!.env.schema

# Build output
dist/
build/
out/
.next/
.nuxt/
.output/

# Cache directories
.cache/
.temp/
.tmp/
.temp/
.cache/
.npm/
.eslintcache
.stylelintcache

# Misc
*.bak
*.tmp
*.temp
*.swp
*.swo
*~
*.pid
*.seed
*.pid.lock

# Ignore certain apps
.config/aws
.foundry

# Raycast: installed-extension build artifacts (minified JS, maps, node_modules
# symlink) - managed by the Raycast app, not config worth versioning.
.config/raycast/

# tmux plugins are installed and managed by tpm (declared via @plugin in
# tmux.conf, installed with <prefix>+I). Not vendored - see README setup.
.config/tmux/plugins/

# configstore: auto-generated app state (npm update-notifier timestamps,
# error-reporting flags), written by CLIs like lighthouse/gemini/vercel. Not config.
.config/configstore/

# Secrets / credentials / machine-specific state (never commit)
.config/neonctl/
.config/gcloud/
.config/op/
# 1Password app config (SSH-agent agent.toml, etc.) references private
# vault/account names and is machine-specific; never commit.
.config/1Password/
# varlock: only an auto-generated telemetry anonymousId, not config worth tracking.
.config/varlock/
.config/tokscale/
.config/raycast/extensions/node_modules
.config/nix/*.bak-*
.config/gh/hosts.yml
.config/hunk/
# Zed: local LMDB prompt-library state (binary, not config)
.config/zed/prompts/
# wrangler: local dev state/cache (tmp, deploy state), written by the CLI. Not config.
.config/.wrangler/
# nix build artifact (darwin-rebuild build drops ./result in cwd)
result
